NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=mysql://iblens:PASSWORD@localhost:3306/iblens

# Session security — generate with: openssl rand -hex 32
JWT_SECRET=

# Google OAuth (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=   # same as GOOGLE_CLIENT_ID (used by frontend)

# Anthropic (LLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5-20251001

# Admin
OWNER_OPEN_ID=      # your Google user ID (returned in first login, check DB)
OWNER_EMAIL=        # your email for admin notifications

# File storage
UPLOADS_DIR=/opt/iblens/uploads
UPLOADS_BASE_URL=https://iblens.com

# Payments — NowPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Payments — LemonSqueezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=

# Email — Resend
RESEND_API_KEY=

# Analytics — GA4
GA4_MEASUREMENT_ID=G-391DXZEC51
GA4_API_SECRET=
